{
  "name": "vscode-super-power",
  "displayName": "VS Code Super Power",
  "description": "Super powers for VS Code — copy file references, and more",
  "repository": {
    "type": "git",
    "url": "https://github.com/JenuelDev/VS-Code-Super-Power.git"
  },
  "version": "0.0.2",
  "publisher": "JenuelDevOfficial",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/icon-256.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-super-power.copyLineReference",
        "title": "Super Power: Copy Line Reference"
      },
      {
        "command": "vscode-super-power.copyFunctionReference",
        "title": "Super Power: Copy Function Reference"
      },
      {
        "command": "vscode-super-power.copyReference",
        "title": "Copy Reference"
      },
      {
        "command": "vscode-super-power.goToReference",
        "title": "Super Power: Go to Reference"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-super-power.goToReference",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vscode-super-power.copyReference",
          "group": "9_cutcopypaste@100"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node ./out/test/runTest.js",
    "pretest": "npm run compile",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
